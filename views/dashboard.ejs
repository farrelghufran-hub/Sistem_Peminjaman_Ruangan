<body class="bg-gray-50 min-h-screen flex flex-col justify-between">

    <nav class="bg-white shadow-md border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <span class="text-xl font-bold text-indigo-600 tracking-wide">🏫 PinjamRuang FTI</span>
                </div>
                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="flex items-center space-x-4">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-semibold text-gray-700"><%= user.nama %></p>
                            <p class="text-xs text-gray-500 capitalize"><%= user.role %></p>
                        </div>
                        <% if (user.foto_profil) { %>
                            <img src="/uploads/profil/<%= user.foto_profil %>" alt="Foto Profil" class="w-10 h-10 rounded-full object-cover border-2 border-indigo-500">
                        <% } else { %>
                            <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center font-bold text-indigo-600">
                                <%= user.nama.charAt(0).toUpperCase() %>
                            </div>
                        <% } %>
                        <form action="/auth/logout" method="POST" class="m-0">
                            <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-semibold transition">
                                Logout
                            </button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
        
        <% if (typeof flashSuccess !== 'undefined' && flashSuccess) { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-xl mb-6 text-sm shadow-sm">
                <span class="font-bold">Sukses:</span> <%= flashSuccess %>
            </div>
        <% } %>
        
        <% if (typeof successMsg !== 'undefined' && successMsg) { %>
            <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-r-xl mb-6 text-sm shadow-sm">
                <%= successMsg %>
            </div>
        <% } %>

        <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
            <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-r-xl mb-6 text-sm shadow-sm">
                <ul class="list-disc pl-5">
                    <% errors.forEach(function(err) { %>
                        <li><%= err %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
